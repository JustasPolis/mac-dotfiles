  email = justas.polikevicius@podimo.com
[core]
  excludesfile = ~/.config/git/ignore
  hooksPath = ~/.config/git-hooks
	pager = delta
	editor = nvim
[credential]
	helper = !glab auth git-credential
[diff]
    external = difft
[difftool "difftastic"]
    cmd = difft "$MERGED" "$LOCAL" "abcdef1" "100644" "$REMOTE" "abcdef2" "100644"
[difftool]
    prompt = false
[pager]
    difftool = true
[diff]
    tool = difftastic
[push]
	autoSetupRemote = true
