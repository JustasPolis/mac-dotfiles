{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "mellowBlue": "#aca1cf",
    "mellowBrightBlue": "#b9aeda",
    "mellowGreen": "#90b99f",
    "mellowGrey": "#7b7b80",
    "mellowYellow": "#e6b99d",
    "mellowMagenta": "#e29eca",
    "mellowPink": "#ea83a5",
    "mellowFg": "#c9c7cd",
    "mellowRed": "#f5a191",
    "mellowBlack": "#27272a",
    "mellowBrightBlack": "#353539",
    "mellowBorder": "#7b7b80"
  },
  "theme": {
    "primary": { "dark": "mellowBlue", "light": "mellowBlue" },
    "secondary": { "dark": "mellowFg", "light": "mellowFg" },
    "accent": { "dark": "mellowBrightBlue", "light": "mellowBrightBlue" },
    "warning": { "dark": "mellowYellow", "light": "mellowYellow" },
    "error": { "dark": "mellowRed", "light": "mellowRed" },
    "success": { "dark": "mellowGreen", "light": "mellowGreen" },
    "info": { "dark": "mellowBlue", "light": "mellowBlue" },
    "text": { "dark": "mellowFg", "light": "mellowFg" },
    "textMuted": { "dark": "mellowGrey", "light": "mellowGrey" },
    "background": { "dark": "none", "light": "none" },
    "backgroundPanel": { "dark": "mellowBlack", "light": "mellowBlack" },
    "backgroundElement": { "dark": "mellowBrightBlack", "light": "mellowBrightBlack" },
    "inputBackground": { "dark": "mellowGrey", "light": "mellowGrey" },
    "border": { "dark": "none", "light": "none" },
    "borderActive": { "dark": "none", "light": "none" },
    "borderSubtle": { "dark": "none", "light": "none" },
    "syntaxKeyword": { "dark": "mellowMagenta", "light": "mellowMagenta" },
    "syntaxFunction": { "dark": "mellowGreen", "light": "mellowGreen" },
    "syntaxVariable": { "dark": "mellowFg", "light": "mellowFg" },
    "syntaxString": { "dark": "mellowYellow", "light": "mellowYellow" },
    "syntaxType": { "dark": "mellowBrightBlue", "light": "mellowBrightBlue" },
    "syntaxNumber": { "dark": "mellowRed", "light": "mellowRed" },
    "syntaxComment": { "dark": "mellowGrey", "light": "mellowGrey" },
    "markdownHeading": { "dark": "mellowPink", "light": "mellowPink" },
    "markdownLink": { "dark": "mellowBlue", "light": "mellowBlue" },
    "markdownCode": { "dark": "mellowYellow", "light": "mellowYellow" },
    "inputCursor": { "dark": "mellowBlue", "light": "mellowBlue" }
  }
}
